<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.slashmad.TimelapseFFmpegGUI</id>
  <name>Timelapse FFmpeg GUI</name>
  <summary>GTK4 timelapse GUI for FFmpeg</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <description>
    <p>Build timelapse videos from image sequences with FFmpeg.</p>
    <ul>
      <li>Paste paths, pick files/folders, or drag and drop images.</li>
      <li>Pick codec, preset, quality (CRF/CQ), pixel format, and FPS.</li>
      <li>See which hardware acceleration options are actually usable.</li>
    </ul>
  </description>
  <screenshots>
